# Environment: local | staging | production
ENV=local

# MLflow Tracking
MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# API Keys (Chrome Extension & Scrapers)
YOUTUBE_API_KEY=your_key_here

# Inference Settings
PREFER_LOCAL_MODEL=false

# Observability: Set to true/1 to enable structured JSON output
JSON_LOGS=false

# Agentic Layer — Content Intelligence Analyst
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (for fallback model)
GROQ_API_KEY=your_groq_key_here

# Hugging Face Token (for fallback model)
HF_TOKEN=your_huggingface_token_here
