# Environment: local | staging | production
ENV=local

# MLflow Tracking
MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# API Keys (Chrome Extension & Scrapers)
YOUTUBE_API_KEY=your_key_here

# Inference Settings
PREFER_LOCAL_MODEL=false

# Observability: Set to true/1 to enable structured JSON output
JSON_LOGS=false
